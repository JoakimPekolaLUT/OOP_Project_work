<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/textCrystals"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crystals: 0"
        android:textSize="18sp" />

    <Button
        android:id="@+id/buttonTrain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Train Selected Crew" />

    <Button
        android:id="@+id/buttonReturnToQuarters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Return Selected to Quarters" />

    <Button
        android:id="@+id/buttonBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back to Menu" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSimulator"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>