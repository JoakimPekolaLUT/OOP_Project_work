<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/textCrystals"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Crystals: 0"
        android:textSize="20sp" />

    <Button
        android:id="@+id/buttonQuarters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quarters" />

    <Button
        android:id="@+id/buttonSimulator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simulator" />

    <Button
        android:id="@+id/buttonMission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mission Control" />

    <Button
        android:id="@+id/buttonStatistics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Statistics" />

</LinearLayout>